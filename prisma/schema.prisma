generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (better-auth) ───
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  projects      Project[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  idToken           String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Projects ───
model Project {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  language    String    @default("en")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]
  memories    ProjectMemory[]
  constraints ProjectConstraint[]
}

// ─── Chat Messages ───
model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String   // "user" | "assistant"
  content   String
  language  String?  // detected language
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Project Memory (auto-saved context) ───
model ProjectMemory {
  id        String   @id @default(cuid())
  projectId String
  type      String   // "goal" | "decision" | "context" | "preference"
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Project Data Store (key-value, backward compat) ───
model ProjectData {
  id        String   @id @default(cuid())
  projectId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
}

// ─── Dynamic Tables for User Apps ───
// Each row belongs to a project + table. Flexible JSON storage.
model AppTable {
  id        String   @id @default(cuid())
  projectId String
  tableName String
  data      String   // JSON object (one row)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, tableName])
  @@index([projectId])
}

// ─── App Users (auth for generated apps) ───
model AppUser {
  id        String   @id @default(cuid())
  projectId String
  email     String
  password  String   // hashed
  name      String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@unique([projectId, email])
  @@index([projectId])
}

// ─── File Storage for User Apps ───
model AppFile {
  id        String   @id @default(cuid())
  projectId String
  fileName  String
  mimeType  String
  size      Int
  data      String   // base64 encoded (for small files)
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ─── Project Files (generated code persistence) ───
model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  path      String   // e.g., "src/App.jsx"
  content   String   // file content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, path])
  @@index([projectId])
}

// ─── SpecLock Constraints (baked-in) ───
model ProjectConstraint {
  id        String   @id @default(cuid())
  projectId String
  text      String
  source    String   @default("auto") // "auto" | "user"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
